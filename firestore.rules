/**
 * Core Philosophy:
 * This ruleset implements a role-based access control (RBAC) model tailored for an educational environment (ScholarlyFlow).
 * The primary security strategy is "Authorization Independence via Denormalization." This means that for rules to be fast,
 * simple, and secure, documents must contain denormalized copies of the user UIDs required for an authorization decision.
 * For example, a 'Class' document should store not just the teacher's entity ID, but their actual user UID ('teacherUserId').
 * This avoids slow and costly multi-document reads (`get()`) within the rules.
 *
 * Data Structure:
 * The data is organized into top-level collections for major entities (users, students, teachers, parents, subjects, classes).
 * Academic data like assignments, grades, and attendance are logically nested as subcollections under `/classes/{classId}`.
 * User-specific private data, such as notifications and student fees, are nested under the relevant user or student path.
 *
 * Key Security Decisions:
 * - User-Ownership: Users have full control over their own '/users/{userId}' document and their private subcollections
 *   like '/users/{userId}/notifications'.
 * - Role-Based Profiles: Specific role profiles (Student, Teacher, Parent) are linked to a primary User account via a `userId`
 *   field. A user can manage their own role profile.
 * - Shared Access for Classes: Access to a class and its subcollections (assignments, exams) is restricted to the assigned
 *   teacher and the enrolled students.
 * - Relational Access for Families: Parents are granted read-access to their children's academic records (grades, attendance, fees)
 *   by checking for their UID in a denormalized `parentUserIds` array on the student's profile.
 * - Public Data: General academic information like '/subjects' is publicly readable to allow for course discovery, but writing
 *   is prohibited for non-admins.
 * - Default Deny: All paths are closed by default. Access is only granted through explicit `allow` statements.
 *
 * Denormalization for Authorization:
 * To make these rules work, your data model MUST include the following denormalized fields:
 * - On 'Class' documents: `teacherUserId` (string) and `studentUserIds` (list<string>).
 * - On 'Student' documents: `userId` (string) and `parentUserIds` (list<string>).
 * - On 'Assignment', 'Exam', and 'Attendance' documents: `teacherUserId` (string).
 * - On 'Submission', 'Grade', 'ExamResult', 'Attendance', and 'Fee' documents: `studentUserId` (string) and `parentUserIds` (list<string>).
 * - On 'Grade' and 'ExamResult' documents: `gradedByTeacherUserId` (string).
 *
 * This approach is critical for creating secure, scalable, and performant security rules.
 */
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------------------------------------------------
    // Helper Functions
    // ---------------------------------------------------------------------

    /**
     * Returns true if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Returns true if the authenticated user's UID matches the provided userId.
     * This is the fundamental check for document ownership.
     * @param userId The UID to check against the authenticated user.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    /**
    * Returns true if the document exists and the user is the owner.
    * Used for state-changing operations like update and delete.
    */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }
    
    /**
     * Checks if the user is the teacher assigned to a specific class.
     * CRITICAL: Assumes the class document has a denormalized 'teacherUserId' field.
     */
    function isClassTeacher(classId) {
      return isSignedIn() && get(/databases/$(database)/documents/classes/$(classId)).data.teacherUserId == request.auth.uid;
    }
    
    /**
     * Checks if the user is a student enrolled in a specific class.
     * CRITICAL: Assumes the class document has a denormalized 'studentUserIds' array.
     */
    function isStudentInClass(classId) {
      return isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/classes/$(classId)).data.studentUserIds;
    }
    
    /**
     * Checks if the user is a member (teacher or student) of a specific class.
     */
    function isClassMember(classId) {
      return isClassTeacher(classId) || isStudentInClass(classId);
    }

    /**
     * Checks if the user is a parent of the student associated with the given data.
     * CRITICAL: Assumes the data contains a denormalized 'parentUserIds' array.
     */
    function isStudentParent(docData) {
      return isSignedIn() && request.auth.uid in docData.parentUserIds;
    }

    // ---------------------------------------------------------------------
    // User Profile Rules
    // ---------------------------------------------------------------------

    /**
     * @description Users can create, read, and update their own profile document. Deletion is disallowed to preserve user history.
     * @path /users/{userId}
     * @allow (create) a new user creating their own profile: `request.auth.uid == userId`.
     * @deny (create) a user trying to create a profile for someone else.
     * @principle Enforces Self-Creation and Ownership for a user's primary identity document.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Disallow listing all users for security.
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if false; // Generally, user profiles should be disabled, not deleted.
    }

    /**
     * @description A user can read, create, and manage their own notifications.
     * @path /users/{userId}/notifications/{notificationId}
     * @allow (get) a user reading their own notification: `request.auth.uid == userId`.
     * @deny (list) a user trying to read notifications of another user.
     * @principle Restricts access to a user's own private data tree.
     */
    match /users/{userId}/notifications/{notificationId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.recipientUserId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.recipientUserId == resource.data.recipientUserId;
      allow delete: if isExistingOwner(userId);
    }

    // ---------------------------------------------------------------------
    // Role Profile Rules (Students, Teachers, Parents)
    // ---------------------------------------------------------------------

    /**
     * @description A student and their legal guardians can view the student's profile. The student can update it.
     * @path /students/{studentId}
     * @allow (get) a parent reading their child's student profile.
     * @deny (update) a parent trying to change their child's profile data.
     * @principle Shared read access for related users, with ownership for writes. Assumes denormalized `parentUserIds`.
     */
    match /students/{studentId} {
      allow get: if isSignedIn() && (isOwner(resource.data.userId) || isStudentParent(resource.data));
      allow list: if false;
      allow create: if isOwner(request.resource.data.userId);
      allow update: if resource != null && isOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if false; // Admin-only task.
    }

    /**
     * @description A teacher can manage their own professional profile.
     * @path /teachers/{teacherId}
     * @allow (update) a teacher updating their own qualifications.
     * @deny (get) one teacher viewing another teacher's private profile details.
     * @principle Enforces document ownership for a role-specific profile.
     */
    match /teachers/{teacherId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if false;
      allow create: if isOwner(request.resource.data.userId);
      allow update: if resource != null && isOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if false; // Admin-only task.
    }

    /**
     * @description A parent can manage their own profile.
     * @path /parents/{parentId}
     * @allow (create) a user creating their parent profile, linking it to their auth UID.
     * @deny (get) one parent viewing another parent's profile.
     * @principle Enforces document ownership for a role-specific profile.
     */
    match /parents/{parentId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if false;
      allow create: if isOwner(request.resource.data.userId);
      allow update: if resource != null && isOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if false; // Admin-only task.
    }
    
    // ---------------------------------------------------------------------
    // Student-Specific Subcollections
    // ---------------------------------------------------------------------
    
    /**
     * @description A student and their parents can view fee information. Writes are restricted.
     * @path /students/{studentId}/fees/{feeId}
     * @allow (get) a student viewing their own fee.
     * @deny (create) a student trying to add or change a fee.
     * @principle Inherits read access from parent document, restricts writes. Assumes denormalization of UIDs.
     */
    match /students/{studentId}/fees/{feeId} {
        allow get, list: if isSignedIn() && (isOwner(get(/databases/$(database)/documents/students/$(studentId)).data.userId) || isStudentParent(get(/databases/$(database)/documents/students/$(studentId)).data));
        allow create: if false; // TODO: Add admin/finance role access.
        allow update: if false; // TODO: Add admin/finance role access.
        allow delete: if false;
    }

    // ---------------------------------------------------------------------
    // Academic Data Rules (Public & Collaborative)
    // ---------------------------------------------------------------------

    /**
     * @description Academic subjects are public information for all authenticated users to read. Only admins can modify.
     * @path /subjects/{subjectId}
     * @allow (list) any authenticated user listing all available subjects.
     * @deny (create) any non-admin user trying to add a new subject.
     * @principle Public read access for non-sensitive, global data with restricted writes.
     */
    match /subjects/{subjectId} {
      allow get, list: if isSignedIn();
      allow create: if false; // TODO: Add admin role access.
      allow update: if false; // TODO: Add admin role access.
      allow delete: if false;
    }

    /**
     * @description Only the teacher and enrolled students of a class can view its details.
     * @path /classes/{classId}
     * @allow (get) an enrolled student viewing their class schedule.
     * @deny (get) a student from another class viewing class details.
     * @principle Shared access for a closed group of collaborators (teacher and students).
     */
    match /classes/{classId} {
      allow get, list: if isClassMember(classId);
      allow create: if false; // TODO: Add admin role access.
      allow update: if false; // TODO: Add admin role access.
      allow delete: if false;
    }

    /**
     * @description Class members can view assignments. Only the class teacher can create or modify them.
     * @path /classes/{classId}/assignments/{assignmentId}
     * @allow (get) an enrolled student reading an assignment's description.
     * @deny (create) a student trying to create an assignment for a class.
     * @principle Access is derived from the parent class membership. Writes are restricted to the owner (teacher).
     */
    match /classes/{classId}/assignments/{assignmentId} {
      allow get, list: if isClassMember(classId);
      allow create: if isClassTeacher(classId) && request.resource.data.teacherUserId == request.auth.uid;
      allow update: if resource != null && isClassTeacher(classId) && request.resource.data.teacherUserId == resource.data.teacherUserId;
      allow delete: if resource != null && isClassTeacher(classId);
    }

    /**
     * @description Students can submit their work. Teachers can view all submissions.
     * @path /classes/{classId}/assignments/{assignmentId}/submissions/{submissionId}
     * @allow (create) a student submitting their assignment.
     * @deny (update) a student trying to modify another student's submission.
     * @principle Combines ownership (for student writes) with role-based access (for teacher reads).
     */
    match /classes/{classId}/assignments/{assignmentId}/submissions/{submissionId} {
      allow get: if isClassTeacher(classId) || isOwner(resource.data.studentUserId);
      allow list: if isClassTeacher(classId) || isStudentInClass(classId); // Students can list their own via query.
      allow create: if isStudentInClass(classId) && isOwner(request.resource.data.studentUserId);
      allow update: if resource != null && isOwner(resource.data.studentUserId) && request.resource.data.studentUserId == resource.data.studentUserId;
      allow delete: if resource != null && isOwner(resource.data.studentUserId);
    }
    
    /**
     * @description Teachers create/update grades. The relevant student and their parents can read the grade.
     * @path /classes/{classId}/assignments/{assignmentId}/grades/{gradeId}
     * @allow (get) a parent viewing their child's grade.
     * @deny (update) a student or parent trying to change a grade.
     * @principle Role-based writes (teacher) and relational-based reads (student, parent).
     */
    match /classes/{classId}/assignments/{assignmentId}/grades/{gradeId} {
      allow get, list: if isClassTeacher(classId) || isOwner(resource.data.studentUserId) || isStudentParent(resource.data);
      allow create: if isClassTeacher(classId) && request.resource.data.gradedByTeacherUserId == request.auth.uid;
      allow update: if resource != null && isClassTeacher(classId) && request.resource.data.gradedByTeacherUserId == resource.data.gradedByTeacherUserId;
      allow delete: if resource != null && isClassTeacher(classId);
    }
    
    /**
     * @description Teachers record attendance. Students and their parents can view attendance records.
     * @path /classes/{classId}/attendanceRecords/{attendanceId}
     * @allow (get) a student viewing their attendance for a class session.
     * @deny (create) a student marking themselves as 'Present'.
     * @principle Role-based writes (teacher) and relational-based reads (student, parent).
     */
    match /classes/{classId}/attendanceRecords/{attendanceId} {
      allow get, list: if isClassTeacher(classId) || isOwner(resource.data.studentUserId) || isStudentParent(resource.data);
      allow create: if isClassTeacher(classId) && request.resource.data.recordedByTeacherUserId == request.auth.uid;
      allow update: if resource != null && isClassTeacher(classId) && request.resource.data.recordedByTeacherUserId == resource.data.recordedByTeacherUserId;
      allow delete: if resource != null && isClassTeacher(classId);
    }

    /**
     * @description Class members can view exams. Only the class teacher can create or modify them.
     * @path /classes/{classId}/exams/{examId}
     * @allow (get) an enrolled student reading an exam's description.
     * @deny (create) a student trying to create an exam for a class.
     * @principle Access is derived from the parent class membership. Writes are restricted to the owner (teacher).
     */
    match /classes/{classId}/exams/{examId} {
      allow get, list: if isClassMember(classId);
      allow create: if isClassTeacher(classId) && request.resource.data.teacherUserId == request.auth.uid;
      allow update: if resource != null && isClassTeacher(classId) && request.resource.data.teacherUserId == resource.data.teacherUserId;
      allow delete: if resource != null && isClassTeacher(classId);
    }

    /**
     * @description Teachers post exam results. The relevant student and their parents can read them.
     * @path /classes/{classId}/exams/{examId}/examResults/{examResultId}
     * @allow (get) a student viewing their own exam result.
     * @deny (update) a student or parent trying to change a score.
     * @principle Role-based writes (teacher) and relational-based reads (student, parent).
     */
    match /classes/{classId}/exams/{examId}/examResults/{examResultId} {
      allow get, list: if isClassTeacher(classId) || isOwner(resource.data.studentUserId) || isStudentParent(resource.data);
      allow create: if isClassTeacher(classId) && request.resource.data.gradedByTeacherUserId == request.auth.uid;
      allow update: if resource != null && isClassTeacher(classId) && request.resource.data.gradedByTeacherUserId == resource.data.gradedByTeacherUserId;
      allow delete: if resource != null && isClassTeacher(classId);
    }
  }
}